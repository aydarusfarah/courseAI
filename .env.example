# ─────────────────────────────────────────────────────────────────────────────
# CourseAI — Environment Variables Template
# Copy this file to .env and fill in ALL required values before running.
# NEVER commit your actual .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, or local Docker)
DATABASE_URL=

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Create a Clerk application at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── AI (OpenAI) ───────────────────────────────────────────────────────────────
# Required for course generation. Get your key at https://platform.openai.com
OPENAI_API_KEY=

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
# Required for subscription billing. Get keys at https://dashboard.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs — create Products + Prices in the Stripe dashboard
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# ── Error Monitoring (Sentry) ─────────────────────────────────────────────────
# Optional. Create a project at https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Analytics (PostHog) ───────────────────────────────────────────────────────
# Optional. Create a project at https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Transactional Email (Resend) ──────────────────────────────────────────────
# Optional. Create an account at https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Caching (Redis) ───────────────────────────────────────────────────────────
# Option 1: ioredis-compatible connection string (local Docker, Upstash TCP)
REDIS_URL=

# Option 2: Upstash REST API (recommended for Vercel / serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
