# CourseAI - .gitignore

# == Environment & Secrets =====================================================
.env
.env.*
**/.env
**/.env.*

# Allow the example template - it contains NO real secret values
!.env.example

# == Clerk (keyless mode stores a live secret key here - NEVER commit) =========
.clerk/
**/.clerk/

# == Dependencies ==============================================================
node_modules/
.pnp
.pnp.js

# == Next.js build output ======================================================
.next/
out/
dist/

# == Build artifacts ===========================================================
build/
*.tsbuildinfo
tsconfig.tsbuildinfo

# == Test output ===============================================================
coverage/
playwright-report/
test-results/
blob-report/
.playwright/

# == Logs ======================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# == Cryptographic material ====================================================
*.pem
*.key
*.crt
*.p12
*.pfx
*.cer
*.der

# == Database files ============================================================
*.sqlite
*.sqlite3
*.db

# == OS & editor artefacts =====================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln

# == Deployment ================================================================
.vercel/

# == Sentry ====================================================================
.sentryclirc

# == Misc ======================================================================
.cache/
.tmp/
*.tmp
*.bak
*.swp
