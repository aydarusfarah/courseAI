# ──────────────────────────────────────────────────────────────────────────────
# .gitattributes — normalize line endings across all platforms
# ──────────────────────────────────────────────────────────────────────────────

# Default: normalize all text files to LF in the repo
* text=auto eol=lf

# Explicitly mark binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.avif binary
*.pdf  binary
*.zip  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
