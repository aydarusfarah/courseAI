            <Link
              href={`/admin/logs?category=${category ?? "all"}&page=${page + 1}`}
              className="rounded-md border px-3 py-1 text-sm"
            >
              Next
            </Link>
          </div>
        </div>
      </Card>
    </div>
  );
}
