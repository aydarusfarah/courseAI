<file path="prisma/schema.prisma">
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(cuid())
  clerkId         String           @unique
  email           String           @unique
  name            String?
  avatarUrl       String?
  role            Role             @default(USER)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  suspended       Boolean          @default(false)
  aiRequests      AIRequest[]
  adminLogs       AdminLog[]
  courses         Course[]
  feedback        Feedback[]
  learningAssets  LearningAsset[]
  payments        Payment[]
  promptTemplates PromptTemplate[]
  subscription    Subscription?
  usageRecords    Usage[]

  @@index([role])
}

model Subscription {
  id          String             @id @default(cuid())
  userId      String             @unique
  stripeId    String?            @unique
  status      SubscriptionStatus
  priceId     String
  interval    BillingInterval
  trialEndsAt DateTime?
  cancelAt    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id             String           @id @default(cuid())
  userId         String
  title          String
  description    String
  topic          String
  audience       String
  difficulty     Difficulty
  language       String
  tone           String
  lessonCount    Int
  duration       String
  status         CourseStatus     @default(DRAFT)
  coverImageUrl  String?
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  archivedAt     DateTime?
  aiRequests     AIRequest[]
  certificate    Certificate?
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions      CourseRevision[]
  exports        Export[]
  learningAssets LearningAsset[]
  modules        Module[]

  @@index([userId, status])
  @@index([topic])
  @@index([difficulty])
}

model Module {
  id        String    @id @default(cuid())
  courseId  String
  title     String
  position  Int
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lessons   Lesson[]
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, position])
}

model Lesson {
  id          String       @id @default(cuid())
  moduleId    String
  title       String
  content     String
  examples    String?
  exercises   String?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  position    Int          @default(0)
  assignments Assignment[]
  flashcards  Flashcard[]
  module      Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questionSet Quiz?

  @@index([moduleId])
}

model Quiz {
  id        String     @id @default(cuid())
  lessonId  String     @unique
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  questions Question[]
  lesson    Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Question {
  id        String    @id @default(cuid())
  quizId    String
  prompt    String
  answer    String
  options   String[]
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  quiz      Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model Flashcard {
  id        String    @id @default(cuid())
  lessonId  String
  front     String
  back      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Assignment {
  id          String    @id @default(cuid())
  lessonId    String
  title       String
  description String
  dueDate     DateTime?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Certificate {
  id        String   @id @default(cuid())
  courseId  String   @unique
  content   String
  issuedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseRevision {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  content   String
  snapshot  String
  author    String?
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, createdAt])
}

model Export {
  id        String     @id @default(cuid())
  courseId  String
  type      ExportType
  url       String?
  deletedAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, type])
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  stripePaymentId String   @unique
  amount          Int
  currency        String
  status          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Usage {
  id        String    @id @default(cuid())
  userId    String
  type      UsageType
  count     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model PromptTemplate {
  id          String       @id @default(cuid())
  userId      String
  name        String
  description String?
  type        TemplateType
  prompt      String
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model AIRequest {
  id            String        @id @default(cuid())
  userId        String
  courseId      String?
  action        RequestAction
